    <string name="settings_srt_section">SRT transport</string>
    <string name="settings_srt_mode">Mode</string>
    <string name="settings_srt_mode_caller">Caller (dial out)</string>
    <string name="settings_srt_mode_listener">Listener (receivers pull)</string>
    <string name="settings_srt_mode_caller_hint">Phone dials out to a remote SRT listener. Easiest path through NAT — the receiver needs a public listener address.</string>
    <string name="settings_srt_mode_listener_hint">Phone listens on the port below. Receivers (VLC, ffmpeg, broadcast software) pull via srt://&lt;phone-ip&gt;:&lt;port&gt;.</string>
    <string name="settings_srt_host">Remote host</string>
    <string name="settings_srt_port">Port</string>
    <string name="settings_srt_passphrase">Encryption passphrase</string>
    <string name="settings_srt_passphrase_hint">10–79 ASCII characters. Blank disables encryption. Receivers must use the same passphrase.</string>
    <string name="settings_srt_latency">Latency window (ms)</string>
    <string name="settings_srt_latency_hint">SRT ARQ window. Lower = lower glass-to-glass delay; higher = better packet-loss tolerance. 120–300 ms typical.</string>
    <string name="settings_srt_streamid">Stream ID (optional)</string>
    <string name="settings_srt_streamid_hint">Sent on connect (CALLER). Receivers use it to route the connection. Leave blank for most setups.</string>
    <string name="settings_protocol_rist">RIST (H.264 + AAC over MPEG-TS)</string>
    <string name="settings_rist_section">RIST transport</string>
    <string name="settings_rist_mode">Mode</string>
    <string name="settings_rist_mode_caller">Caller (dial out)</string>
    <string name="settings_rist_mode_listener">Listener (receivers pull)</string>
    <string name="settings_rist_mode_caller_hint">Phone dials out to a remote RIST receiver. Easiest path through NAT, and the only mode that can target a multicast group address.</string>
    <string name="settings_rist_mode_listener_hint">Phone binds the port and waits for the receiver to dial in, learning the caller\'s source port from its first packet and replying there. Verified to work with librist receivers (OBS, VLC, ffmpeg, ristreceiver) on the Main profile.</string>
    <string name="settings_rist_listener_needs_main">Listener needs the Main profile — Simple profile is Caller-only (librist receivers can\'t dial a Simple-profile listener).</string>
    <string name="settings_rist_host">Remote host</string>
    <string name="settings_rist_port">Port (data)</string>
    <string name="settings_rist_port_hint">RTP/MPEG-TS data port. RTCP feedback runs on this port + 1, so the receiver must reach both.</string>
    <string name="settings_rist_profile">Profile</string>
    <string name="settings_rist_profile_simple">Simple (RTP + retransmit)</string>
    <string name="settings_rist_profile_main">Main (GRE tunnel + AES)</string>
    <string name="settings_rist_profile_simple_hint">Simple Profile: RTP/MPEG-TS with RTCP-NACK retransmit. Interoperable with virtually every RIST receiver. No encryption (that\'s a Main-profile feature).</string>
    <string name="settings_rist_profile_main_hint">Main Profile: GRE-encapsulated over a single UDP port with AES encryption (set a passphrase below). NULL-packet suppression and DTLS are not implemented; everything else is per VSF TR-06-2.</string>
    <string name="settings_rist_passphrase">Encryption passphrase</string>
    <string name="settings_rist_passphrase_hint">AES passphrase (Main Profile). Blank = GRE without encryption. Receivers must use the same passphrase. Ignored under Simple Profile.</string>
    <string name="settings_rist_aes">AES key length</string>
    <string name="settings_rist_aes_128">AES-128</string>
    <string name="settings_rist_aes_256">AES-256</string>
    <string name="settings_rist_buffer">Buffer window (ms)</string>
    <string name="settings_rist_buffer_hint">Retransmit / receiver jitter window. Lower = lower glass-to-glass delay; higher = better packet-loss tolerance. 120–300 ms typical.</string>
    <string name="settings_rist_rotation_note">Rotation follows the phone live — turn the device while streaming and the picture rotates to match.</string>
