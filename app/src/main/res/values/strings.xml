    <!-- Help tooltips shown when the user clicks the `?` icon next to a setting on the
         web panel. Each one explains a single field in 1–2 sentences. Keyed by the
         setting's name (lowercased, no underscores) — the key lives in the HTML as
         `data-help="…"`. -->
    <string name="web_help_lens">Which physical camera to use. Front = selfie camera; back = main camera.</string>
    <string name="web_help_resolution">Frame size. Higher = sharper picture, more bandwidth, more battery.</string>
    <string name="web_help_fps">Frames per second. 30 is the standard. 60 and above need the RTSP protocol and a high-speed-capable lens.</string>
    <string name="web_help_rotation_lock">Forces the MJPEG stream to a specific orientation no matter how the phone is held.</string>
    <string name="web_help_mirror">Flips the picture left-right. Common for selfie/vlog setups so on-screen text reads normally on your phone.</string>
    <string name="web_help_continuous_af">When on, the camera continuously refocuses on the scene. When off, focus is locked at the last tap point.</string>
    <string name="web_help_watermark">Burns a text label into every MJPEG frame. The literal `%t` is replaced with the current HH:mm:ss.</string>
    <string name="web_help_exposure">Brightens (+) or darkens (−) the picture without changing ISO or shutter speed.</string>
    <string name="web_help_white_balance">Adjusts colour temperature for the lighting type. Auto works in most rooms.</string>
    <string name="web_help_antibanding">Removes the horizontal flicker bands you sometimes see under fluorescent or mains-powered lights. Match your country\'s mains: 50 Hz in Europe, 60 Hz in North America.</string>
    <string name="web_help_effect">Built-in colour effects baked into the stream. \"None\" is normal video.</string>
    <string name="web_help_scene">Hints the camera about what kind of scene you\'re shooting so it can tune exposure / focus automatically.</string>
    <string name="web_help_manual_focus">Disables autofocus and uses the Focus distance slider instead.</string>
    <string name="web_help_focus_distance">How far the camera is focused. 0 = infinity, higher values = closer to the lens. Only used while Manual focus is on.</string>
    <string name="web_help_manual_exposure">Disables auto-exposure and uses the ISO and Shutter sliders instead. Useful for fixed-lighting scenes where AE keeps drifting.</string>
    <string name="web_help_iso">Sensor sensitivity. Lower = cleaner picture, needs more light. Only used while Manual exposure is on.</string>
    <string name="web_help_shutter">How long each frame is exposed, in microseconds. Shorter = sharper motion, dimmer picture. Only used while Manual exposure is on.</string>
    <string name="web_help_stream_mic">Sends the phone\'s microphone audio alongside the video. Requires the Microphone permission.</string>
    <string name="web_help_mic_source">Which Android microphone preset to use. Camcorder is good for most cases; Voice communication adds aggressive echo/noise cancel for calls.</string>
    <string name="web_help_gain">Amplifies the microphone signal in software. +6 dB doubles the loudness; clipping happens above 0 dBFS on the meter.</string>
    <string name="web_help_noise_suppress">Lets Android\'s built-in noise suppressor try to remove background hum and hiss. Quality varies by device.</string>
    <string name="web_help_echo_cancel">Lets Android\'s built-in echo canceller remove playback echo from the mic. Mostly useful in two-way calls.</string>
    <string name="web_help_jpeg_quality">JPEG compression level for the MJPEG stream. Higher = sharper picture, larger frames, more bandwidth. 80 is a good default.</string>
    <string name="web_help_rtsp_bitrate">Target bitrate for the H.264 encoder. 0 lets Lenscast pick from resolution × FPS. Lower it for slow Wi-Fi.</string>
    <string name="web_help_mjpeg_sidecar">When on, the MJPEG /video endpoint runs alongside RTSP using the same camera capture. Lets a browser preview while OBS pulls RTSP. Capped at ≤30 fps.</string>
    <string name="web_help_record_mp4">Saves the RTSP stream to an MP4 file in Movies/Lenscast/ while streaming. Encoded once, no extra battery cost.</string>
    <string name="web_help_sftp_auto_upload">When the recording finishes, queue it for SFTP upload to the server you configure below.</string>
    <string name="web_help_sftp_host">Hostname or IP of the SSH/SFTP server.</string>
    <string name="web_help_sftp_port">SSH port. 22 is the default.</string>
    <string name="web_help_sftp_user">Username on the SFTP server.</string>
    <string name="web_help_sftp_password">Password on the SFTP server. Key-auth isn\'t supported yet.</string>
    <string name="web_help_sftp_remote_dir">Folder on the server to upload into. Created if missing. Blank = the user\'s home directory.</string>
    <string name="web_help_sftp_fingerprint">Pin the server\'s SHA-256 fingerprint to defeat MITM. Blank = trust whatever key the server presents (LAN-only setups).</string>
    <string name="web_help_keep_screen_on">Prevents the phone screen from sleeping while streaming. Higher battery cost.</string>
    <string name="web_help_blank_preview">Saves battery by not rendering the preview on the phone while streaming. The stream itself still goes out.</string>
    <string name="web_help_auto_start">Start streaming immediately whenever the app is opened, with the last-used settings.</string>
    <string name="web_help_start_on_boot">Start streaming automatically when the phone finishes booting. Requires the app to be excluded from battery optimisation.</string>
    <string name="web_help_mjpeg_port">TCP port the MJPEG server listens on. Receivers connect to <code>&lt;phone-ip&gt;:&lt;this-port&gt;/video</code>.</string>
    <string name="web_help_rtsp_port">TCP port the RTSP server listens on. OBS / VLC / ffmpeg connect to <code>rtsp://&lt;phone-ip&gt;:&lt;this-port&gt;/lenscast</code>.</string>
    <string name="web_help_https">Wraps the MJPEG and web-control ports in TLS. Receivers will see a self-signed-cert warning the first time.</string>
    <string name="web_help_stream_user">Username the receiver will be asked for. Defaults to \"Lenscast\" when blank.</string>
    <string name="web_help_stream_pass">Password the receiver will be asked for. Blank = open access to anyone on your network.</string>
    <string name="web_help_call_behavior">What should happen to the stream when a phone call comes in. Mute and Drop require the Phone permission.</string>
    <string name="web_help_persistent_web">Keeps this web control panel reachable when the app is backgrounded. Adds a persistent low-priority notification.</string>
    <string name="web_help_export">Download every setting as a JSON file you can re-import on another phone.</string>
    <string name="web_help_import">Replace every setting with a previously-exported JSON blob. Stream must be stopped.</string>

